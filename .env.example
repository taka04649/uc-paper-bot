# Anthropic Claude API キー（必須）
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Discord Webhook URL（必須）
# Discord チャンネル設定 → 連携サービス → ウェブフック で作成
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxxxxx/xxxxxxxxxxxxxxxxxxxxxxxx

# PubMed API キー（任意・推奨）
# https://account.ncbi.nlm.nih.gov/ → Account Settings → API Key Management
PUBMED_API_KEY=

# PubMed に渡すメールアドレス（任意・推奨）
PUBMED_EMAIL=your_email@example.com
